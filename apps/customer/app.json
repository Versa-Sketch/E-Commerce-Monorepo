{
  "expo": {
    "jsEngine": "hermes",
    "name": "E-Commerce_app",
    "slug": "E-Commerce_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ecommerceapp",
    "userInterfaceStyle": "automatic",
    "androidStatusBar": {
      "barStyle": "dark-content",
      "backgroundColor": "#00000000",
      "translucent": true
    },
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.yaswanthram.ECommerce-app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to show nearby stores within a 6 km radius.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We need your location to show nearby stores within a 6 km radius.",
        "NSLocationAlwaysUsageDescription": "We need your location to show nearby stores within a 6 km radius."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.yaswanthram.ECommerce_app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
